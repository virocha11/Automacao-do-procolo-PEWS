# Chamadas diretas do navegador para a API (sem proxy). Ex.: http://localhost:3000
# Deixe vazio no dev com Vite para usar o prefixo /api e o proxy.
# Não use http://backend:3000 aqui — o navegador não resolve esse hostname.

# VITE_API_URL=

# Só para o servidor do Vite (proxy). No Docker o compose define http://backend:3000.
# VITE_API_PROXY_TARGET=http://127.0.0.1:3000
